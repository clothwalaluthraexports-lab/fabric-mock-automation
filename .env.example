# ─────────────────────────────────────────────────────────────────────────────
# FABRIC MOCK AUTOMATION — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub. Add .env to your .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Your Gemini API key (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive folder IDs (get these from the URL of each folder in Drive)
# Example URL: https://drive.google.com/drive/folders/1ABC123XYZ
# The folder ID is the part after /folders/
DRIVE_INPUT_FOLDER_ID=your_input_folder_id_here
DRIVE_OUTPUT_FOLDER_ID=your_output_folder_id_here

# Google Service Account credentials JSON (as a single-line JSON string)
# OR set GOOGLE_SERVICE_ACCOUNT_FILE to the path of your JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Output image format: jpg or png (default: jpg)
OUTPUT_FORMAT=jpg

# Max retries per mock generation if Gemini fails (default: 3)
MAX_RETRIES=3

# Delay in seconds between each design file to respect API rate limits (default: 5)
DELAY_BETWEEN_DESIGNS=5

# Set to true to move processed source files to a /Processed subfolder in Drive
MOVE_PROCESSED_FILES=true
